{
  "manifest_version": 3,
  "name": "Neuro-Inclusive Web Interface",
  "version": "1.0.0",
  "description": "AI-assisted cognitively accessible, distraction-free reading for ADHD, autism, and dyslexia.",
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Neuro-Inclusive"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ]
}
